# App
NODE_ENV=development
NEXT_PUBLIC_APP_NAME="Sedori AI"
APP_URL=http://localhost:3000

# Database
# Supabase / Prisma
# DATABASE_URL はアプリ実行用。Supabase の Transaction pooler URL を推奨。
# DIRECT_URL は Prisma migrate / db push 用。Supabase の Direct connection URL を指定。
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&schema=public"
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?schema=public"
SUPABASE_URL="https://PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Redis / BullMQ
REDIS_URL="redis://localhost:6379"

# Auth placeholder
SESSION_SECRET="replace-with-strong-random-secret"
SALES_API_KEY="replace-with-strong-random-api-key"
# Vercel Cron 認証用。Vercel ダッシュボードでも同じ値を設定すること。
CRON_SECRET=""
# 画面の Basic Auth 用(両方セットされたときだけ画面に認証ゲートが入る)。
SITE_USERNAME=""
SITE_PASSWORD=""

# OpenAI
OPENAI_API_KEY=""

# KMS. Use aws_kms or gcp_kms in production. local_dev is for development only.
ENCRYPTION_PROVIDER="local_dev"
AWS_REGION="ap-northeast-1"
AWS_KMS_KEY_ID=""
GCP_KMS_KEY_NAME=""

# External APIs
KEEPA_API_KEY=""
RAKUTEN_APPLICATION_ID=""
RAKUTEN_APP_ID=""
RAKUTEN_ACCESS_KEY=""
RAKUTEN_AFFILIATE_ID=""
# Optional fixed-IP proxy. Use this when Rakuten IP restrictions block Vercel.
RAKUTEN_PROXY_URL=""
RAKUTEN_PROXY_API_KEY=""
YAHOO_CLIENT_ID=""
YAHOO_CLIENT_SECRET=""
# NETSEA Web API(卸)
# NETSEA_API_BASE_URL は実際の本番ベースURL(NETSEAから提供される)を設定。例: https://api.netsea.jp/v1
NETSEA_API_BASE_URL=""
NETSEA_API_TOKEN=""

# Optional Amazon SP-API
AMAZON_SP_API_ENABLED="false"
AMAZON_LWA_CLIENT_ID=""
AMAZON_LWA_CLIENT_SECRET=""
AMAZON_REFRESH_TOKEN=""
AMAZON_SELLER_ID=""
AMAZON_MARKETPLACE_ID="A1VC38T7YXB528"
AMAZON_AWS_ROLE_ARN=""
